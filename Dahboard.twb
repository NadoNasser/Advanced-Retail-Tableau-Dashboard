      <aliases enabled='yes' />
      <column caption='Year of Order' datatype='integer' name='[Calculation_0081091317284866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Date])' />
      </column>
      <column caption='Total Sales' datatype='real' name='[Calculation_0918095920111616]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Quantity] * [Price] * (1 - [Discount]))' />
      </column>
      <column caption='Total Profit' datatype='real' name='[Calculation_0918095920427009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(([Quantity] * [Price] * (1 - [Discount])) - ([Quantity] * [Cost_Price]))' />
      </column>
      <column caption='Dynamic Metric Field' datatype='real' name='[Calculation_0918095921233922]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Sales&quot; THEN [Calculation_0918095920111616]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Profit&quot; THEN [Calculation_0918095920427009]&#13;&#10;END' />
      </column>
      <column caption='Dynamic Dimension Field' datatype='string' name='[Calculation_0918095922536451]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &quot;Category&quot; THEN [Category]&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &quot;Region&quot; THEN [Region]&#13;&#10;END' />
      </column>
      <column caption='Show Trend' datatype='boolean' name='[Calculation_0918095957102596]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 3] = &quot;Trend View&quot;' />
      </column>
      <column caption='Show Table' datatype='boolean' name='[Calculation_0918095957307397]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 3] = &quot;Table View&quot;' />
      </column>
      <column caption='Category Drilldown' datatype='string' name='[Calculation_0918095958786054]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Category Set] THEN [Product_Name] ELSE &quot;&quot; END' />
      </column>
      <column caption='Total Procurement Cost' datatype='real' name='[Calculation_0918096222859271]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Quantity] * [Cost_Price])' />
      </column>
      <column caption='Active Suppliers' datatype='integer' name='[Calculation_0918096222949384]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Supplier_ID])' />
      </column>
      <column caption='Profit Margin %' datatype='real' name='[Calculation_0918096223145993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0918095920427009] / [Calculation_0918095920111616]) * 100' />
      </column>
      <column datatype='string' name='[Category]' role='dimension' type='nominal' />
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column caption='Contact Email' datatype='string' name='[Contact_Email]' role='dimension' type='nominal' />
      <column caption='Contact Person' datatype='string' name='[Contact_Person]' role='dimension' type='nominal' />
      <column caption='Cost Price' datatype='real' name='[Cost_Price]' role='measure' type='quantitative' />
      <column caption='Customer ID' datatype='string' name='[Customer_ID]' role='dimension' type='nominal' />
      <column datatype='date' name='[Date (Months)]' role='dimension' type='quantitative' user:agg-type='Month-Trunc' user:base-field='Date' user:ui-builder='date-bin-builder'>
        <calculation class='tableau' formula='DATE(DATETRUNC(&apos;month&apos;, [Date]))' />
      </column>
      <column caption='Product ID' datatype='string' name='[Product_ID]' role='dimension' type='nominal' />
      <column caption='Product Name' datatype='string' name='[Product_Name]' role='dimension' type='nominal' />
      <column datatype='integer' name='[Quantity]' role='measure' type='quantitative' />
      <column datatype='string' name='[Region]' role='dimension' type='nominal' />
